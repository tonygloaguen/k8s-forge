replicaCount: [[ values.replica_count ]]

image:
  repository: [[ values.image_repository | yaml_scalar ]]
  tag: [[ values.image_tag | yaml_scalar ]]
  pullPolicy: IfNotPresent

service:
  enabled: [[ values.service_enabled | lower ]]
  type: ClusterIP
  port: [[ values.service_port ]]
  targetPort: [[ values.service_target_port ]]

config:
[% if values.config %]
[% for key, value in values.config.items() %]
  [[ key ]]: [[ value | yaml_scalar ]]
[% endfor %]
[% else %]
  {}
[% endif %]

secrets:
  enabled: [[ values.secrets_enabled | lower ]]
  values:
[% if values.secrets %]
[% for key, value in values.secrets.items() %]
    [[ key ]]: [[ value | yaml_scalar ]]
[% endfor %]
[% else %]
    {}
[% endif %]

resources:
  requests:
[% if values.resources.requests %]
[% for key, value in values.resources.requests.items() %]
    [[ key ]]: [[ value | yaml_scalar ]]
[% endfor %]
[% else %]
    {}
[% endif %]
  limits:
[% if values.resources.limits %]
[% for key, value in values.resources.limits.items() %]
    [[ key ]]: [[ value | yaml_scalar ]]
[% endfor %]
[% else %]
    {}
[% endif %]

probes:
  liveness: [[ values.probes.liveness | yaml_scalar ]]
  readiness: [[ values.probes.readiness | yaml_scalar ]]

autoscaling:
  enabled: [[ values.autoscaling.enabled | lower ]]
  minReplicas: [[ values.autoscaling.minReplicas ]]
  maxReplicas: [[ values.autoscaling.maxReplicas ]]
  targetCPUUtilizationPercentage: [[ values.autoscaling.targetCPUUtilizationPercentage ]]

securityContext:
  pod:
    runAsNonRoot: true
    runAsUser: 10001
  container:
    allowPrivilegeEscalation: false
    readOnlyRootFilesystem: true
    dropAllCapabilities: true

ingress:
  enabled: [[ values.ingress.enabled | lower ]]
  host: [[ values.ingress.host | yaml_scalar ]]
  className: [[ values.ingress.className | yaml_scalar ]]
  path: [[ values.ingress.path | yaml_scalar ]]
  pathType: [[ values.ingress.pathType | yaml_scalar ]]
  tls:
    enabled: [[ values.ingress.tls.enabled | lower ]]
    secretName: [[ values.ingress.tls.secretName | yaml_scalar ]]
  certManager:
    enabled: [[ values.ingress.certManager.enabled | lower ]]
    clusterIssuer: [[ values.ingress.certManager.clusterIssuer | yaml_scalar ]]
  annotations:
[% if values.ingress.annotations %]
[% for key, value in values.ingress.annotations.items() %]
    [[ key | yaml_scalar ]]: [[ value | yaml_scalar ]]
[% endfor %]
[% else %]
    {}
[% endif %]
mesh:
  enabled: [[ values.mesh.enabled | lower ]]
  provider: [[ values.mesh.provider | yaml_scalar ]]
  inject: [[ values.mesh.inject | lower ]]
  annotations:
[% if values.mesh.annotations %]
[% for key, value in values.mesh.annotations.items() %]
    [[ key | yaml_scalar ]]: [[ value | yaml_scalar ]]
[% endfor %]
[% else %]
    {}
[% endif %]
networkPolicy:
  enabled: [[ values.networkPolicy.enabled | lower ]]
  profile: [[ values.networkPolicy.profile | yaml_scalar ]]
  ingress:
    enabled: [[ values.networkPolicy.ingress.enabled | lower ]]
    fromNamespaces:
[% for namespace in values.networkPolicy.ingress.fromNamespaces %]
      - [[ namespace | yaml_scalar ]]
[% endfor %]
    ports:
[% for port in values.networkPolicy.ingress.ports %]
      - [[ port ]]
[% endfor %]
  egress:
    enabled: [[ values.networkPolicy.egress.enabled | lower ]]
policy:
  enabled: [[ values.policy.enabled | lower ]]
  provider: [[ values.policy.provider | yaml_scalar ]]
  profile: [[ values.policy.profile | yaml_scalar ]]
  validationFailureAction: [[ values.policy.validationFailureAction | yaml_scalar ]]
  background: [[ values.policy.background | lower ]]
  rules:
    requireRecommendedLabels: [[ values.policy.rules.requireRecommendedLabels | lower ]]
    disallowPrivilegedContainers: [[ values.policy.rules.disallowPrivilegedContainers | lower ]]
    requireRunAsNonRoot: [[ values.policy.rules.requireRunAsNonRoot | lower ]]
    requireResources: [[ values.policy.rules.requireResources | lower ]]
    disallowLatestTag: [[ values.policy.rules.disallowLatestTag | lower ]]
