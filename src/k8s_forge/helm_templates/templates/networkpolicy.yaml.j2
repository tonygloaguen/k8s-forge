{{- if .Values.networkPolicy.enabled }}
apiVersion: networking.k8s.io/v1
kind: NetworkPolicy
metadata:
  name: {{ include "[[ chart_name ]].fullname" . }}-ingress-only
  labels:
    {{- include "[[ chart_name ]].labels" . | nindent 4 }}
spec:
  podSelector:
    matchLabels:
      {{- include "[[ chart_name ]].selectorLabels" . | nindent 6 }}
  policyTypes:
    - Ingress
  {{- if .Values.networkPolicy.ingress.enabled }}
  ingress:
    - from:
        {{- range .Values.networkPolicy.ingress.fromNamespaces }}
        - namespaceSelector:
            matchLabels:
              kubernetes.io/metadata.name: {{ . | quote }}
        {{- end }}
      ports:
        {{- range .Values.networkPolicy.ingress.ports }}
        - protocol: TCP
          port: {{ . }}
        {{- end }}
  {{- else }}
  ingress: []
  {{- end }}
{{- end }}
