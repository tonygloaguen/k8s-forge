apiVersion: kyverno.io/v1
kind: Policy
metadata:
  name: {{ (app.name ~ "-baseline") | tojson }}
  namespace: {{ app.namespace | tojson }}
  labels:
{% for key, value in labels.items() %}
    {{ key | tojson }}: {{ value | tojson }}
{% endfor %}
spec:
  validationFailureAction: {{ policy.validationFailureAction | tojson }}
  background: {{ policy.background | lower }}
  rules:
{% if policy.rules.requireRecommendedLabels %}
    - name: require-recommended-labels
      match:
        any:
          - resources:
              kinds:
                - Deployment
                - Service
                - ConfigMap
                - Secret
                - Ingress
                - NetworkPolicy
      validate:
        message: "Recommended Kubernetes app labels are required."
        pattern:
          metadata:
            labels:
              app.kubernetes.io/name: "?*"
              app.kubernetes.io/managed-by: "?*"
{% endif %}
{% if policy.rules.disallowPrivilegedContainers %}
    - name: disallow-privileged-containers
      match:
        any:
          - resources:
              kinds:
                - Pod
                - Deployment
      validate:
        message: "Privileged containers are not allowed."
        pattern:
          spec:
            =(template):
              spec:
                containers:
                  - =(securityContext):
                      =(privileged): false
            =(containers):
              - =(securityContext):
                  =(privileged): false
{% endif %}
{% if policy.rules.requireRunAsNonRoot %}
    - name: require-run-as-non-root
      match:
        any:
          - resources:
              kinds:
                - Pod
                - Deployment
      validate:
        message: "Pods should run as non-root."
        anyPattern:
          - spec:
              securityContext:
                runAsNonRoot: true
          - spec:
              template:
                spec:
                  securityContext:
                    runAsNonRoot: true
{% endif %}
{% if policy.rules.requireResources %}
    - name: require-resources
      match:
        any:
          - resources:
              kinds:
                - Pod
                - Deployment
      validate:
        message: "Containers should define CPU and memory requests and limits."
        pattern:
          spec:
            =(template):
              spec:
                containers:
                  - resources:
                      requests:
                        cpu: "?*"
                        memory: "?*"
                      limits:
                        cpu: "?*"
                        memory: "?*"
            =(containers):
              - resources:
                  requests:
                    cpu: "?*"
                    memory: "?*"
                  limits:
                    cpu: "?*"
                    memory: "?*"
{% endif %}
{% if policy.rules.disallowLatestTag %}
    - name: disallow-latest-tag
      match:
        any:
          - resources:
              kinds:
                - Pod
                - Deployment
      validate:
        message: "Container images should use an explicit tag instead of latest."
        pattern:
          spec:
            =(template):
              spec:
                containers:
                  - image: "!*:latest"
            =(containers):
              - image: "!*:latest"
{% endif %}
