name: k8s-forge Image Security

on:
  push:
  pull_request:

jobs:
  image-security:
    name: Container scan and SBOM
    runs-on: ubuntu-latest
    steps:
      - name: Checkout repository
        uses: actions/checkout@v4

      - name: Build container image locally
        run: docker build -t {{ image }} -f {{ ci.container.dockerfile }} {{ ci.container.context }}

      - name: Prepare reports directory
        run: mkdir -p reports

{% if ci.container.scan.enabled %}
      - name: Install Trivy
        run: |
          curl -sfL https://raw.githubusercontent.com/aquasecurity/trivy/main/contrib/install.sh | sh -s -- -b "$HOME/.local/bin"
          echo "$HOME/.local/bin" >> "$GITHUB_PATH"

      - name: Scan image with Trivy
        run: trivy image --severity {{ severity_csv }} {{ image }}

      - name: Export Trivy JSON report
        run: trivy image --severity {{ severity_csv }} --format json --output reports/trivy-image.json {{ image }}

{% endif %}
{% if ci.container.sbom.enabled %}
      - name: Install Syft
        run: |
          curl -sSfL https://raw.githubusercontent.com/anchore/syft/main/install.sh | sh -s -- -b "$HOME/.local/bin"
          echo "$HOME/.local/bin" >> "$GITHUB_PATH"

      - name: Generate SBOM with Syft
        run: syft {{ image }} -o {{ ci.container.sbom.format }}={{ sbom_output }}

{% endif %}
{% if ci.artifacts.enabled %}
      - name: Upload security reports
        uses: actions/upload-artifact@v4
        with:
          name: image-security-reports
          path: reports/
          if-no-files-found: warn
{% endif %}
