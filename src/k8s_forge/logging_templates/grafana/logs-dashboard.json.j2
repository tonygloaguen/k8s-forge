{
  "uid": "{{ app.name }}-logs-readiness",
  "title": {{ dashboard_title | tojson }},
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "tags": ["k8s-forge", "logging-readiness", "loki"],
  "timezone": "browser",
  "panels": [
    {
      "id": 1,
      "type": "logs",
      "title": "Recent logs",
      "description": "Recent logs for the application namespace. Adapt labels if your collector uses different label names.",
      "targets": [
        {
          "expr": "{namespace=\"{{ app.namespace }}\"}",
          "refId": "A"
        }
      ],
      "gridPos": {"h": 10, "w": 24, "x": 0, "y": 0}
    },
    {
      "id": 2,
      "type": "logs",
      "title": "Error logs",
      "description": "Example error filter for the namespace.",
      "targets": [
        {
          "expr": "{namespace=\"{{ app.namespace }}\"} |= \"ERROR\"",
          "refId": "A"
        }
      ],
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 10}
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Log volume",
      "description": "Example log volume query for the namespace.",
      "targets": [
        {
          "expr": "count_over_time({namespace=\"{{ app.namespace }}\"}[5m])",
          "refId": "A"
        }
      ],
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 10}
    },
    {
      "id": 4,
      "type": "logs",
      "title": "Application logs by app label",
      "description": "Uses the app label generated by k8s-forge. Adapt this selector if Loki exposes a different label name.",
      "targets": [
        {
          "expr": "{namespace=\"{{ app.namespace }}\", app=\"{{ app.name }}\"}",
          "refId": "A"
        }
      ],
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 18}
    }
  ]
}
