variable "project_name" {
  description = "Educational Terraform project name generated from app.yaml."
  type        = string
  default     = "{{ project_name }}"
}

variable "app_name" {
  description = "Application name from app.yaml."
  type        = string
  default     = "{{ app.name }}"
}

variable "namespace" {
  description = "Kubernetes namespace from app.yaml."
  type        = string
  default     = "{{ app.namespace }}"
}

variable "chart_path" {
  description = "Local Helm chart path example for this application."
  type        = string
  default     = "{{ chart_path }}"
}

variable "kubeconfig_path" {
  description = "Optional path to an existing local cluster config file. No file is generated by k8s-forge."
  type        = string
  default     = ""
}

variable "create_namespace_example" {
  description = "Controls the educational namespace resource example in main.tf."
  type        = bool
  default     = false
}

variable "enable_helm_release_example" {
  description = "Controls the educational Helm release example in main.tf."
  type        = bool
  default     = false
}
