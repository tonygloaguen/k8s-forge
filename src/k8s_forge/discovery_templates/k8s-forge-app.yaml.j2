# Generated by k8s-forge discover.
# This is a starter configuration and readiness scaffold.
# Review is required. This file is not deployment-ready by default.
# It does not prove Kubernetes compatibility.
app:
  name: {{ result.suggested_config.app_name }}
  namespace: {{ result.suggested_config.namespace }}
  image: {{ result.suggested_config.image }}
  containerPort: {{ result.suggested_config.container_port }}
  replicas: {{ result.suggested_config.replicas }}

config:
  enabled: true
  data:
{% for key, value in result.suggested_config.config.items() %}
    {{ key }}: "{{ value }}"
{% endfor %}

secrets: {}

service:
  enabled: true
  port: {{ result.suggested_config.service_port }}

resources:
  requests:
    cpu: "50m"
    memory: "64Mi"
  limits:
    cpu: "250m"
    memory: "128Mi"

probes:
  liveness: null
  readiness: null

autoscaling:
  enabled: false
  minReplicas: 2
  maxReplicas: 6
  targetCPUUtilizationPercentage: 70

ingress:
  enabled: false
  host: null
  className: nginx
  path: /
  pathType: Prefix
  tls:
    enabled: false
    secretName: null
  certManager:
    enabled: false
    clusterIssuer: null
  annotations: {}

networkPolicy:
  enabled: false
  profile: ingress-only
  ingress:
    enabled: true
    fromNamespaces:
      - ingress-nginx
    ports:
      - {{ result.suggested_config.container_port }}
  egress:
    enabled: false

policy:
  enabled: false
  provider: kyverno
  profile: baseline
  validationFailureAction: Audit
  background: true
  rules:
    requireRecommendedLabels: true
    disallowPrivilegedContainers: true
    requireRunAsNonRoot: true
    requireResources: true
    disallowLatestTag: true

supplyChain:
  enabled: false

ci:
  enabled: false

gitops:
  enabled: false

observability:
  enabled: false

logging:
  enabled: false

tracing:
  enabled: false

terraform:
  enabled: false

ansible:
  enabled: false

security:
  enabled: false

capstone:
  enabled: false
